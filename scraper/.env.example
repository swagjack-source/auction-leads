# Copy this to .env for local testing (never commit .env)

# Your Supabase project URL (found in Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role secret key — NOT the anon key (found in Settings → API → service_role)
# This bypasses Row Level Security so the scraper can write to the table
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: override the CTBids URL (defaults to Denver Southeast)
# CTBIDS_URL=https://ctbids.com/estate-sales/Denver-Southeast-CO

# Optional: cron schedule (defaults to every 30 minutes)
# CRON_SCHEDULE=*/30 * * * *
